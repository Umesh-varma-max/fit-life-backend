# .env.example — COMMIT THIS (no real secrets)

# Flask
SECRET_KEY=change-this-in-production
FLASK_ENV=development
FLASK_DEBUG=1

# JWT
JWT_SECRET_KEY=change-this-jwt-secret

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://username:password@ep-example.ap-southeast-1.aws.neon.tech/fitness_db?sslmode=require

# Groq AI (FREE — get key at https://console.groq.com)
GROQ_API_KEY=gsk_REPLACE_ME

# CORS
FRONTEND_ORIGIN=http://localhost:3000
